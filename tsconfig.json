{
	"compilerOptions": {
		"target": "ESNext",
		"moduleResolution": "bundler",
		"module": "CommonJS",
		"rootDir": "./src",
		"outDir": "./dist",
		"strict": true,
		"sourceMap": false,
		"alwaysStrict": true,
		"removeComments": false,
		"noImplicitAny": true,
		"noUnusedLocals": true,
		"noImplicitReturns": true,
		"noUnusedParameters": false,
		"skipLibCheck": true,
		"esModuleInterop": true,
		"declaration": true
	},
	"include": [
		"./src/**/*"
	],
	"exclude": [
		"node_modules"
	]
}